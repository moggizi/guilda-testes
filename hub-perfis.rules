rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /chave/{docId} {
      allow create: if true;
      allow read: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /perfil/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;

      match /{document=**} {
        allow read: if true;
        allow create: if true;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
